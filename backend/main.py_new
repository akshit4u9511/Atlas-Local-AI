# Setup Directories
BASE_DIR = os.path.dirname(os.path.dirname(__file__))
GEN_DIR = os.path.join(BASE_DIR, 'generated')
UPLOAD_DIR = os.path.join(GEN_DIR, 'faceswap', 'input')
os.makedirs(UPLOAD_DIR, exist_ok=True)

for d in ['images', 'videos', 'audio', 'faceswap/output']:
    os.makedirs(os.path.join(GEN_DIR, d), exist_ok=True)

database.init_db()

app = FastAPI(title="Atlas Multimodal API")
app.add_middleware(CORSMiddleware, allow_origins=["*"], allow_credentials=True, allow_methods=["*"], allow_headers=["*"])

app.mount("/generated/images", StaticFiles(directory=os.path.join(GEN_DIR, 'images')), name="images")
app.mount("/generated/videos", StaticFiles(directory=os.path.join(GEN_DIR, 'videos')), name="videos")
app.mount("/generated/audio", StaticFiles(directory=os.path.join(GEN_DIR, 'audio')), name="audio")
app.mount("/generated/faceswap", StaticFiles(directory=os.path.join(GEN_DIR, 'faceswap', 'output')), name="faceswap")

MODEL_PATH = os.path.join(BASE_DIR, 'models', 'Mistral-7B-Instruct-v0.3.Q4_K_M.gguf')
llm_instance = None

def free_vram_except(keep: str):
    print(f"[*] Allocating VRAM for '{keep}'. Evicting other pipelines...")
    global llm_instance
    if keep != "llm" and llm_instance:
        print("[*] Unloading MS-7B from VRAM...")
        del llm_instance
        llm_instance = None
    
    if keep != "image": image_gen.unload_image_pipeline()
    if keep != "video": video_gen.unload_video_pipeline()
    if keep != "audio": audio_gen.unload_audio_pipeline()
    if keep != "faceswap": faceswap_handler.unload_faceswap()
    
    gc.collect()
    if 'torch' in sys.modules:
        import torch
        if torch.cuda.is_available():
            torch.cuda.empty_cache()

def get_llm():
    global llm_instance
    if llm_instance is None:
        free_vram_except("llm")
        print("[*] Loading Mistral-7B to GPU...")
        llm_instance = LlamaCpp(
            model_path=MODEL_PATH, temperature=0.3, max_tokens=1024, n_ctx=4096,
            n_gpu_layers=33, n_threads=8, streaming=True, verbose=False,
        )
    return llm_instance

@app.post("/upload-media")
async def upload_media(file: UploadFile = File(...)):
    filename = f"{uuid.uuid4().hex}_{file.filename}"
    file_path = os.path.join(UPLOAD_DIR, filename)
    with open(file_path, "wb") as buffer:
        shutil.copyfileobj(file.file, buffer)
    return {"status": "success", "filename": filename}

@app.post("/faceswap")
async def faceswap_endpoint(
    conversation_id: str = Form(...),
    source_filename: str = Form(...),
    target_filename: str = Form(...)
):
    free_vram_except("faceswap")
    database.create_conversation(conversation_id)
    database.add_message(conversation_id, "user", f"[Face Swap Request]: {source_filename} onto {target_filename}")
    
    result_filename = faceswap_handler.process_face_swap(source_filename, target_filename)
    
    if result_filename:
        url = f"/generated/faceswap/{result_filename}"
        database.add_message(conversation_id, "assistant", "Face swap complete!", message_type="image", file_path=url)
        return {"status": "success", "file_path": url}
    return {"status": "error", "message": "Face swap failed."}

